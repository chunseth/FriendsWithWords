# Required for all edge functions
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# FCM: use HTTP v1 (recommended) or legacy key
# v1: from Firebase Console > Project settings > Service accounts > Generate new private key (JSON). Use:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Raw PEM (private_key from JSON), with literal \n or base64-encoded
FIREBASE_PRIVATE_KEY=
# Legacy (deprecated, disabled for new projects): Cloud Messaging > Server key
# FCM_SERVER_KEY=

# APNs JWT auth
APNS_TEAM_ID=
APNS_KEY_ID=
# Raw PEM with literal \n escapes, or base64-encoded PEM
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
APNS_USE_SANDBOX=true

# Event-driven push rollout
ENABLE_EVENT_DRIVEN_PUSH=false
EVENT_DRIVEN_PUSH_CANARY_PERCENT=0

# Reminder cron + reminder push rollout
ENABLE_CRON_REMINDERS=false
ENABLE_REMINDER_PUSH=false
REMINDER_PUSH_CANARY_PERCENT=0

# Server-authoritative push queue worker
ENABLE_NOTIFICATION_QUEUE_PUSH=true
NOTIFICATION_QUEUE_BATCH_SIZE=100
